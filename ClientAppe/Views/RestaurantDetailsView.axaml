<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClientAppe.ViewModels"
             xmlns:m="using:ClientAppe.Models"
             x:Class="ClientAppe.Views.RestaurantDetailsView"
             x:DataType="vm:RestaurantDetailsViewModel">

    <DockPanel Background="#F7F9FC">
        <Border DockPanel.Dock="Top"
                Background="White"
                Height="70"
                BoxShadow="0 2 10 0 #10000000">
            <Grid ColumnDefinitions="Auto, *, Auto"
                  Margin="30,0">
                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Border Width="40" 
                            Height="40"
                            Background="#5849E8"
                            CornerRadius="10"
                            Margin="0,0,10,0">
                        <PathIcon Data="{StaticResource home_regular}"
                                  Foreground="White"
                                  Width="20" 
                                  Height="20"/>
                    </Border>
                    <TextBlock Text="FoodHub"
                               FontSize="22"
                               FontWeight="ExtraBold"
                               Foreground="#1A1A1A"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="25" 
                            VerticalAlignment="Center">
                    <Button Content="Головна"
                            Classes="navLink"
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToHomeCommand}"/>
                    <Button Content="Профіль"
                            Classes="navLink" 
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToProfileCommand}"/>
                    <Button Content="Замовлення"
                            Classes="navLink"
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToOrdersCommand}"/>
                    
                    <Button Background="#F1F5F9" 
                            Padding="12,8"
                            CornerRadius="10"
                            Cursor="Hand"
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToCartCommand}">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Text="Кошик"
                                       Foreground="#1A1A1A"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer>
            <StackPanel>
                <Panel Height="350">
                    <Border Background="#2D3748"/> 
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,100%"
                                                 EndPoint="0%,0%">
                                <GradientStop Offset="0" 
                                              Color="#CC000000"/>
                                <GradientStop Offset="0.7"
                                              Color="#00000000"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border HorizontalAlignment="Left" 
                            VerticalAlignment="Top" 
                            Margin="30,20" 
                            CornerRadius="20" 
                            BoxShadow="0 4 12 0 #40000000">
                        <Button Classes="backBtn" 
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).GoBackCommand}">
                            <TextBlock Text="←"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#5849E8" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Border>

                    <StackPanel VerticalAlignment="Bottom" 
                                Margin="60,40"
                                Spacing="15">

                        <TextBlock Text="{Binding RestaurantName}"
                                   FontSize="48" 
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="{Binding Description}" 
                                   Foreground="#CBD5E0" 
                                   FontSize="18" 
                                   MaxWidth="700" 
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="25">

                            <StackPanel Orientation="Horizontal" 
                                        Spacing="8">

                                <TextBlock Text="★"
                                           Foreground="#FACC15"
                                           Width="16"
                                           Height="16"/>

                                <TextBlock Text="4.8"
                                           Foreground="White" 
                                           FontWeight="Bold"
                                           FontSize="16"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" 
                                        Spacing="8">

                                <PathIcon Data="{StaticResource clock_regular}"
                                          Foreground="White" 
                                          Width="18" 
                                          Height="18"/>

                                <TextBlock Text="30-45 хв"
                                           Foreground="White" 
                                           FontSize="16"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">

                                <PathIcon Data="{StaticResource location_regular}" 
                                          Foreground="White" 
                                          Width="18" 
                                          Height="18"/>

                                <TextBlock Text="1.2 км" 
                                           Foreground="White" 
                                           FontSize="16"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Panel>

                <ItemsControl ItemsSource="{Binding Categories}"
                              Margin="60,30,60,10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="15"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
<ItemsControl.ItemTemplate>
    <DataTemplate>
        <Button Classes="categoryTab"
                Command="{Binding $parent[UserControl].((vm:RestaurantDetailsViewModel)DataContext).SelectCategoryCommand}"
                CommandParameter="{Binding}">

            <TextBlock Text="{Binding}" 
                       Foreground="#1A202C"
                       FontWeight="SemiBold"/>
        </Button>
    </DataTemplate>
</ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding MenuItems}"
                              Margin="60,20">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="m:FoodModel">
                            <Border Width="380" Margin="0,0,30,30"
                                    Background="White"
                                    CornerRadius="24" 
                                    BoxShadow="0 10 25 0 #08000000">
                                <StackPanel>
                                  <Border Height="220" 
                                   CornerRadius="24,24,0,0"
                                   Background="#F1F5F9" 
                                   ClipToBounds="True">
                                     <Panel>
                                      <TextBlock Text="🍲"
                                      FontSize="50"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                      
                                  <Image Source="{Binding ImageBitmap}" 
                                   Stretch="UniformToFill"/>
                                     </Panel>
                                  </Border>

                                    <StackPanel Margin="25" 
                                                Spacing="12">

                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="20" 
                                                   FontWeight="Bold" 
                                                   Foreground="#1A202C"/>

                                        <TextBlock Text="{Binding Description}" 
                                                   Foreground="#718096"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"
                                                   Height="45"/>

                                        <Grid ColumnDefinitions="*, Auto" 
                                              Margin="0,15,0,0">
                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">

                                                <TextBlock Text="{Binding Price}"
                                                           FontSize="22" 
                                                           FontWeight="ExtraBold"
                                                           Foreground="#5849E8"/>

                                                <TextBlock Text=" грн" 
                                                           FontSize="22" 
                                                           FontWeight="ExtraBold"
                                                           Foreground="#5849E8"/>
                                            </StackPanel>

<Panel Grid.Column="1"
       VerticalAlignment="Center">
    <Button Content="+ Додати"
            Classes="addBtn"
            IsVisible="{Binding IsNotInCart}"
            Command="{Binding $parent[UserControl].((vm:RestaurantDetailsViewModel)DataContext).AddToCartCommand}"
            CommandParameter="{Binding}"/>

    <Grid ColumnDefinitions="Auto, Auto, Auto"
          IsVisible="{Binding IsInCart}">
        <Button Grid.Column="0"
                Content="-" 
                Classes="counterBtn"
                Command="{Binding $parent[UserControl].((vm:RestaurantDetailsViewModel)DataContext).RemoveFromCartCommand}" 
                CommandParameter="{Binding}"/>
        
        <TextBlock Grid.Column="1" 
                   Text="{Binding Quantity}"
                   Foreground="#1A1A1A"
                   Margin="10,0" 
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   FontSize="16"/>
        
        <Button Grid.Column="2"
                Content="+"
                Classes="counterBtn"
                Command="{Binding $parent[UserControl].((vm:RestaurantDetailsViewModel)DataContext).AddToCartCommand}" 
                CommandParameter="{Binding}"/>
    </Grid>
</Panel>                                    </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

    <UserControl.Styles>
        <Style Selector="Button.navLink">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.navLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#5849E8"/>
        </Style>

        <Style Selector="Button.categoryTab">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>

        <Style Selector="Button.addBtn">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.addBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.backBtn">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
        <Style Selector="Button.backBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#5849E8"/>
        </Style>
        <Style Selector="Button.counterBtn">
            <Setter Property="Width" Value="32"/> <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
        <Style Selector="Button.counterBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E2E8F0"/> 
            <Setter Property="Foreground" Value="#1A1A1A"/> </Style>
    </UserControl.Styles>
</UserControl>