<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClientAppe.ViewModels"
             x:Class="ClientAppe.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="RestaurantGrad" 
                             StartPoint="0%,0%"
                             EndPoint="100%,100%">
            <GradientStop Offset="0"
                          Color="#FF8C42"/>
            <GradientStop Offset="1" 
                          Color="#FF5733"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="FastFoodGrad"
                             StartPoint="0%,0%"
                             EndPoint="100%,100%">
            <GradientStop Offset="0" 
                          Color="#FFD93D"/>
            <GradientStop Offset="1"
                          Color="#FF8C42"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="OtherGrad"
                             StartPoint="0%,0%" 
                             EndPoint="100%,100%">
            <GradientStop Offset="0"
                          Color="#B197FC"/>
            <GradientStop Offset="1"
                          Color="#E599F7"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <DockPanel Background="#F7F9FC">
        <Border DockPanel.Dock="Top"
                Background="White" 
                Height="70"
                BoxShadow="0 2 10 0 #10000000">
            <Grid ColumnDefinitions="Auto, *, Auto" 
                  Margin="30,0">
                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Border Width="40" 
                            Height="40" 
                            Background="#5849E8"
                            CornerRadius="10"
                            Margin="0,0,10,0">
                        <PathIcon Data="{StaticResource home_regular}"
                                  Foreground="White"
                                  Width="20" 
                                  Height="20"/>
                    </Border>
                    <TextBlock Text="FoodHub"
                               FontSize="22"
                               FontWeight="ExtraBold"
                               Foreground="#1A1A1A"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="25" 
                            VerticalAlignment="Center">
                    <Button Content="Головна"
                            Classes="navLink" 
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToHomeCommand}"/>
                    <Button Content="Профіль"
                            Classes="navLink" 
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToProfileCommand}"/>
                    <Button Content="Замовлення"
                            Classes="navLink" 
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToOrdersCommand}"/>
                    
                    <Button Background="#F1F5F9"
                            Padding="12,8"
                            CornerRadius="10"
                            Cursor="Hand"
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToCartCommand}">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Text="Кошик"
                                       Foreground="#1A1A1A"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

<ScrollViewer>
            <StackPanel Margin="40"
                        Spacing="50">
                <TextBlock Text="Оберіть категорію закладу"
                           FontSize="32"
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Foreground="#1E293B"/>

                <UniformGrid Columns="3" 
                             HorizontalAlignment="Center"
                             MaxWidth="1100">
                   <Border Classes="cardHolder"
                           Background="{StaticResource RestaurantGrad}">
                        <Button Classes="categoryCard" 
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToRestaurantsCommand}" 
                                CommandParameter="Ресторани">
                            <StackPanel Spacing="20">
                                <Border Width="80" 
                                        Height="80"
                                        CornerRadius="40"
                                        Background="#44FFFFFF">
                                    <TextBlock Text="🍴"
                                               FontSize="40"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/> 
                                </Border>
                                <TextBlock Text="Ресторани"
                                           FontSize="22" 
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Classes="cardHolder"
                            Background="{StaticResource FastFoodGrad}">
                        <Button Classes="categoryCard"
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToRestaurantsCommand}" 
                                CommandParameter="Фаст-фуд">
                            <StackPanel Spacing="20">
                                <Border Width="80" 
                                        Height="80" 
                                        CornerRadius="40"
                                        Background="#44FFFFFF">
                                    <TextBlock Text="🍔" 
                                               FontSize="40"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Фаст-фуд"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                    <Border Classes="cardHolder"
                            Background="{StaticResource OtherGrad}">
                        <Button Classes="categoryCard"
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToRestaurantsCommand}" 
                                CommandParameter="Інше">
                            <StackPanel Spacing="20">
                                <Border Width="80" 
                                        Height="80"
                                        CornerRadius="40" 
                                        Background="#44FFFFFF">
                                    <TextBlock Text="✨" 
                                               FontSize="40"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Інше"
                                           FontSize="22" 
                                           FontWeight="Bold" 
                                           Foreground="White" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </UniformGrid>

                <StackPanel MaxWidth="900"
                            HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                Margin="0,0,0,15">
                        <PathIcon Data="{StaticResource location_regular}" 
                                  Foreground="#5849E8" 
                                  Width="18"/>
                        <TextBlock Text="Адреса доставки" 
                                   FontWeight="SemiBold"
                                   Foreground="#4A5568"/>
                    </StackPanel>
                    
                    <Border Background="White"
                            CornerRadius="30"
                            Padding="40"
                            BoxShadow="0 10 30 0 #10000000">
                        <StackPanel Spacing="25">
                            <Grid>
                                <TextBox Text="{Binding DeliveryAddress}"
                                         Watermark="м. Київ, вул. Хрещатик, 1"
                                         Height="60" 
                                         CornerRadius="15" 
                                         Padding="50,0,15,0"
                                         VerticalContentAlignment="Center"
                                         Background="#F8FAFC" 
                                         BorderThickness="0"
                                         Foreground="#1A1A1A"/>
                                <PathIcon Data="{StaticResource location_regular}" 
                                          Foreground="#94A3B8"
                                          Width="18"
                                          HorizontalAlignment="Left"
                                          Margin="18,0,0,0"/>
                            </Grid>

                            <Button Content="Вибрати на карті" 
                                    Classes="primaryBtn"
                                    Command="{Binding OpenMapCommand}"/>

                            <TextBlock Text="{Binding StatusMessage}" 
                                       Foreground="#5849E8" 
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" 
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

<UserControl.Styles>
    <Style Selector="Button.navLink">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#64748B"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.navLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="Foreground" Value="#5849E8"/>
    </Style>

    <Style Selector="Button.activeNavLink">
        <Setter Property="Background" Value="#5849E8"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>
    
    <Style Selector="Button.activeNavLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#4F46E5"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>


    <Style Selector="Border.cardHolder">
        <Setter Property="Width" Value="320"/>
        <Setter Property="Height" Value="240"/>
        <Setter Property="CornerRadius" Value="35"/>
        <Setter Property="Margin" Value="15"/>
        <Setter Property="BoxShadow" Value="0 10 25 0 #30000000"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.cardHolder:pointerover">
        <Setter Property="RenderTransform" Value="translateY(-8px)"/>
    </Style>

    <Style Selector="Button.categoryCard">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
		<Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <Style Selector="Button.categoryCard:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>


    <Style Selector="Button.primaryBtn">
        <Setter Property="Background" Value="#5849E8"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Height" Value="55"/>
        <Setter Property="Width" Value="280"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
		<Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.primaryBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#4F46E5"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
</UserControl.Styles>
</UserControl>