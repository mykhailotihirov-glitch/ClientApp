<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClientAppe.ViewModels"
             xmlns:m="using:ClientAppe.Models"
             x:Class="ClientAppe.Views.RestaurantsView"
             x:DataType="vm:RestaurantsViewModel">

    <DockPanel Background="#F7F9FC">
        <Border DockPanel.Dock="Top" 
                Background="White"
                Height="70"
                BoxShadow="0 2 10 0 #10000000">
            <Grid ColumnDefinitions="Auto, *, Auto" 
                  Margin="30,0">
                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Border Width="40" 
                            Height="40"
                            Background="#5849E8"
                            CornerRadius="10"
                            Margin="0,0,10,0">
                        <PathIcon Data="{StaticResource home_regular}" 
                                  Foreground="White" 
                                  Width="20"
                                  Height="20"/>
                    </Border>
                    <TextBlock Text="FoodHub" 
                               FontSize="22" 
                               FontWeight="ExtraBold"
                               Foreground="#1A1A1A"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="25" 
                            VerticalAlignment="Center">
                    <Button Content="Головна"
                            Classes="navLink" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToHomeCommand}"/>
                    <Button Content="Профіль"
                            Classes="navLink" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToProfileCommand}"/>
                    <Button Content="Замовлення" 
                            Classes="navLink" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToOrdersCommand}"/>
                    
                    <Button Background="#F1F5F9"
                            Padding="12,8"
                            CornerRadius="10"
                            Cursor="Hand"
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToCartCommand}">
                        <StackPanel Orientation="Horizontal" 
                                    Spacing="8">
                            <TextBlock Text="Кошик" 
                                       Foreground="#1A1A1A" 
                                       FontWeight="SemiBold" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer>
            <StackPanel Margin="40">
<StackPanel Orientation="Horizontal" 
            Spacing="20"
            Margin="0,0,0,10">
    <Border CornerRadius="20" 
            BoxShadow="0 4 8 0 #10000000">
        <Button Classes="backBtn" 
                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).GoBackCommand}">
            <TextBlock Text="←"
                       FontSize="20"
                       FontWeight="Bold" 
                       Foreground="#5849E8" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
        </Button>
    </Border>
    <TextBlock Text="Заклади" 
               FontSize="32" 
               FontWeight="Bold"
               Foreground="#1E293B" 
               VerticalAlignment="Center"/>
</StackPanel>

                <TextBlock Text="{Binding FoundCountText, FallbackValue='Знайдено 3 заклади'}"
                           Foreground="#94A3B8" 
                           Margin="60,0,0,25" 
                           FontSize="16"/>

<StackPanel Orientation="Horizontal"
            Spacing="15"
            Margin="30,10,30,20">
    <Button Content="Всі заклади"
            Classes="filterBtn"
            Command="{Binding FilterCategoryCommand}" 
            CommandParameter="Всі заклади"/>

    <Button Content="Ресторани" 
            Classes="filterBtn"
            Command="{Binding FilterCategoryCommand}" 
            CommandParameter="Ресторани"/>

    <Button Content="Фаст-фуд"
            Classes="filterBtn"
            Command="{Binding FilterCategoryCommand}" 
            CommandParameter="Фаст-фуд"/>

    <Button Content="Інше"
            Classes="filterBtn"
            Command="{Binding FilterCategoryCommand}" 
            CommandParameter="Інше"/>
</StackPanel>

<StackPanel Orientation="Horizontal" 
            Spacing="10" 
            Margin="0,0,0,30">
            
    <Button Content="За рейтингом"
            Classes="sortBtn"
            Command="{Binding SortCommand}"
            CommandParameter="Rating"/>
            
    <Button Content="Швидка доставка"
            Classes="sortBtn"
            Command="{Binding SortCommand}"
            CommandParameter="Fastest"/>
</StackPanel>

                <ItemsControl ItemsSource="{Binding Restaurants}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="m:RestaurantModel">
                            <Button Classes="restaurantCardBtn" 
                                    Command="{Binding $parent[UserControl].((vm:RestaurantsViewModel)DataContext).NavigateToDetailsCommand}"
                                    CommandParameter="{Binding}">
                                <Border Width="350"
                                        CornerRadius="24"
                                        Background="White" 
                                        BoxShadow="0 10 30 0 #08000000"
                                        Margin="0,0,10,10">
                                    <StackPanel>
                                        <Panel Height="200">
<Border CornerRadius="24,24,0,0" 
        Background="#F1F5F9"
        ClipToBounds="True">
    <Panel>
        <PathIcon Data="{StaticResource image_regular}" 
                  Width="40" 
                  Height="40"
                  Foreground="#CBD5E0"/>
        
        <Image Source="{Binding ImageBitmap}" 
               Stretch="UniformToFill"/>
    </Panel>
</Border>
                                            <Border Background="#FF6B00"
                                                    CornerRadius="12" 
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="15" 
                                                    Padding="12,6">
                                                <TextBlock Text="Популярне"
                                                           Foreground="White" 
                                                           FontSize="12" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </Panel>

                                        <StackPanel Margin="24">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="22"
                                                       FontWeight="Bold" 
                                                       Foreground="#1E293B"/>
                                              <TextBlock Text="{Binding Category}"
                                                         Foreground="#718096"
                                                         FontSize="14"/>
                                            
                                            <StackPanel Orientation="Horizontal" 
                                                        Spacing="20" 
                                                        Margin="0,12,0,0">
                                                
                                                <StackPanel Orientation="Horizontal" 
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    
                                                    <TextBlock Text="★"
                                                               Foreground="#FACC15" 
                                                               Width="16"
                                                               Height="16"/>

                                                    <TextBlock Text="{Binding Rating}"
                                                               FontWeight="Bold"
                                                               Foreground="#1E293B"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <PathIcon Data="{StaticResource clock_regular}" 
                                                              Foreground="#94A3B8" 
                                                              Width="16"
                                                              Height="16"/>

                                                    <TextBlock Text="{Binding DeliveryTime}" 
                                                               Foreground="#64748B"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                
                                            </StackPanel>
                                            <Separator Background="#F1F5F9" 
                                                       Margin="0,20"/>

                                            <TextBlock Text="Графік роботи: 08:00 - 22:00"
                                                       FontSize="13" 
                                                       Foreground="#94A3B8"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

    <UserControl.Styles>
        <Style Selector="Button.backBtn">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
        <Style Selector="Button.backBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#5849E8"/>
        </Style>

        <Style Selector="Button.filterBtn">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Foreground" Value="#475569"/>
        </Style>
        <Style Selector="Button.filterBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#5849E8"/>
        </Style>
        <Style Selector="Button.filterBtn.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.restaurantCardBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,25,25"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.restaurantCardBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <Style Selector="Button.navLink">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.navLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#5849E8"/>
        </Style>

<Style Selector="Button.sortBtn">
    <Setter Property="Background" Value="#F8FAFC"/>
    <Setter Property="Foreground" Value="#64748B"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="CornerRadius" Value="10"/>
</Style>

<Style Selector="Button.sortBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#F1F5F9"/>
    <Setter Property="Foreground" Value="#5849E8"/>
</Style>

<Style Selector="Button.sortBtn.active /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#EEF2FF"/>
    <Setter Property="Foreground" Value="#5849E8"/>
</Style>
    </UserControl.Styles>
</UserControl>